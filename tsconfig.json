{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@Application/*": ["./src/application/*"],
      "@Domain/*": ["./src/app/domain/*"],
      "@Infrastructure/*": ["./src/infrastructure/*"],
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}